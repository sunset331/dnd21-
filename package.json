{
  "name": "dnd-pet",
  "version": "1.2.0",
  "description": "挂机养成 DND 桌宠 — 旅行青蛙 × DND 跑团",
  "author": "sunset331",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.dnd.dice-pet",
    "productName": "DND-Dice-Pet",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "src/**/*",
      "!src/assets/animations/**/*.png"
    ],
    "win": {
      "target": "portable",
      "icon": "src/assets/tray_icon.png"
    }
  }
}
